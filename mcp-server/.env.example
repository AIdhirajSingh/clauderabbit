# ClaudeRabbit MCP server — configuration
#
# ClaudeRabbit is a free, no-login, public tool: the Supabase URL and the
# Supabase PUBLISHABLE key are not secrets (they are the exact two values the
# public web app ships in its own client bundle — see the root .env.example
# and docs/INFRASTRUCTURE.md §3/§7). This server ships with them as built-in
# defaults so it works out of the box with zero configuration.
#
# Only set these if you are pointing the server at a different ClaudeRabbit
# deployment (e.g. a fork or a staging project).

# Supabase project URL for the ClaudeRabbit deployment to call.
# CLAUDE_RABBIT_SUPABASE_URL=https://mjvlczaytkhvsolnhhkz.supabase.co

# Supabase PUBLISHABLE key (sb_publishable_...) — safe to ship client-side,
# this is the same key the ClaudeRabbit web app uses for anonymous scans.
# CLAUDE_RABBIT_SUPABASE_PUBLISHABLE_KEY=sb_publishable_HAPgnT9M5Sr166Se8Nx0yg_qxzn-08B

# Public site origin used to build the "view full report" link returned by
# the tool. Defaults to the real production domain below; override only for a
# fork, a staging deployment, or local dev against `npm run dev` (http://localhost:2311).
# CLAUDE_RABBIT_SITE_URL=https://clauderabbit.in

# Request timeout for the scan_repo tool, in milliseconds. A fresh (uncached)
# scan streams NDJSON stage events and can take tens of seconds; this bounds
# how long the tool call will block waiting for the final result.
# CLAUDE_RABBIT_SCAN_TIMEOUT_MS=120000
