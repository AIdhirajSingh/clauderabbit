{
  "name": "clauderabbit-mcp",
  "version": "0.1.0",
  "private": true,
  "description": "MCP server for ClaudeRabbit — lets AI coding tools scan a public GitHub repo or check for an existing safety report before installing/using it.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "clauderabbit-mcp": "dist/index.js"
  },
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "build": "npm run clean && tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "dev": "tsc -p tsconfig.json --watch",
    "test:smoke": "node dist/test/smoke.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^3.25.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "typescript": "^5.7.2"
  }
}
