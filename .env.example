# Claude Rabbit — client environment (Vercel: set these as Project Environment Variables)
# Only PUBLISHABLE / public values belong here. NEVER put a secret key, service-account JSON,
# or model API key in the client env or the repo — those live ONLY in Supabase edge-function
# secrets (see docs/INFRASTRUCTURE.md §7).

# Supabase project URL
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co

# Supabase PUBLISHABLE key (new key system, sb_publishable_...). Safe for the client bundle.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxx

# Public site origin (used for metadataBase, OG tags, OAuth/email redirect URLs)
NEXT_PUBLIC_SITE_URL=http://localhost:2311

# --- Server-side secrets are NOT set here. They are set in Supabase edge-function secrets:
#   GOOGLE_SERVICE_ACCOUNT_JSON, GCP_PROJECT_ID, GCP_LOCATION,
#   GEMINI_FAST_MODEL, GEMINI_DEEP_MODEL, GITHUB_TOKEN (optional),
#   CR_DEEP_RUNNER_KEY  (authorizes the attach-forensics endpoint; see below)
# via: supabase secrets set NAME="value"

# ============================================================================
# LOCAL SANDBOX CONTROLLER ONLY — set these in `.env.local` on the machine that
# actually runs deep scans (it needs gcloud + bash). They are read by the Next.js
# server (the /api/deep route), are SERVER-ONLY (never NEXT_PUBLIC, never shipped
# to the client), and DO NOT belong in the Vercel Project Env — the inline deep
# path cannot spawn VMs on Vercel and stays inert there. `.env.local` is gitignored.
# ============================================================================

# Opt THIS machine's /api/deep route in. Unset/!=1 → the route is inert (403), so
# it is safe by default on any deploy. Set to 1 only on a trusted local controller.
# CR_ALLOW_LOCAL_DEEP=1

# GCP zone the detonation + trap VMs boot in (must match the golden image's region).
# CR_SANDBOX_ZONE=us-central1-a

# The runner token gating the attach-forensics endpoint. GENERATE one (openssl rand
# -hex 32) and set the SAME value in BOTH Supabase secrets AND here, so the inline
# route can persist forensics. This is an app-defined token, NOT a Supabase service
# or account credential.
# CR_DEEP_RUNNER_KEY=<64-hex>

# Optional — only if the server is launched with a narrow PATH that can't resolve
# git-bash / gcloud / python3 (e.g. some process managers). Point at the absolute
# bash and prepend the tool dirs onto the child PATH. A shell with a complete PATH
# needs neither (BASH defaults to "bash", the prepend defaults to empty).
# CR_BASH=C:\Program Files\Git\usr\bin\bash.exe
# CR_SANDBOX_PATH_PREPEND=<dir;dir;...>  (Windows: ; separated · POSIX: : separated)
